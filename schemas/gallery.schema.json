{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CAD Gallery Configuration",
  "description": "Configuration for the CAD Gallery build pipeline",
  "type": "object",
  "properties": {
    "freecad_dir": {
      "type": "string",
      "description": "Directory containing .FCStd files (non-recursive search)",
      "default": "."
    },
    "metadata_dir": {
      "type": "string",
      "description": "Directory containing metadata YAML files and images",
      "default": "metadata"
    },
    "output_dir": {
      "type": "string",
      "description": "Output directory for the generated gallery site",
      "default": "gallery"
    },
    "exports_dir": {
      "type": "string",
      "description": "Directory for exported STL/STEP files",
      "default": "exports"
    }
  },
  "additionalProperties": false
}
